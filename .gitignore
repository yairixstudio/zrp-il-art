# original (uncompressed) media — kept locally only
_originals/

# raw import material — never published (images/ ships only processed WebP+AVIF)
**/_import/
images/**/*.png
images/**/*.jpg
events/**/*.jpg
events/**/*.png

# macOS duplicate-file artifacts ("name 2.ext")
**/* 2.*

# macOS
.DS_Store
**/.DS_Store

# Editor / IDE
.idea/
.vscode/
.cursor/

# Claude Code local config (do not publish)
.claude/

# Logs / scratch
*.log
.tmp/
tmp/
.local-server.pid

# Node / Lighthouse (dev tooling only — not part of the published site)
node_modules/
lighthouse-reports/

# staged-but-unpublished pages (hidden until reveal; not served by GitHub Pages)
_staging/
